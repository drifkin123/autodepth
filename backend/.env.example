BAT_LIST_PAGE_DELAY_MAX=8
BAT_DETAIL_DELAY_MIN=5
BAT_DETAIL_DELAY_MAX=12
BAT_TARGET_DELAY_MIN=30
BAT_TARGET_DELAY_MAX=120
BAT_STOP_ON_BLOCK=true
BAT_SKIP_ENRICHED_DETAILS=true
